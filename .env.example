# Server Configuration
PORT=3000

# Shopify Configuration
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here

# Shopify Admin API (REQUIRED for new customer detection)
# Without these, the app cannot reliably determine if a customer is new
# Get these from: Shopify Admin > Settings > Apps and sales channels > Develop apps
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx

# Slack Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# LLM Configuration (at least one required for enrichment)
# OpenRouter example: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_MODEL=moonshotai/kimi-k2.6

# Anthropic fallback (optional)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Search API Configuration
# Brave Search API - https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# Agent Behavior
ONLY_NEW_CUSTOMERS=true  # Set to false to alert on all orders
